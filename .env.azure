# ── Azure OpenAI Mode ─────────────────────────────────────────────────────────
# Usage:
#   copy .env.azure .env
#   docker compose -f docker-compose.openai.yml up --build
#
# Find these values in Azure Portal → Azure OpenAI → Keys and Endpoint

OPENAI_PROVIDER=azure

# Your Azure OpenAI resource endpoint (from Azure Portal)
OPENAI_ENDPOINT=https://{your-resource-name}.openai.azure.com

# Azure OpenAI API key (Key 1 or Key 2 from Azure Portal)
AZURE_OPENAI_KEY=...your-azure-openai-key...

# Your deployment name (created in Azure OpenAI Studio)
AZURE_DEPLOYMENT=gpt-4o

# Model name (used for labelling only in Azure mode)
OPENAI_MODEL=gpt-4o

# Azure API version (use latest stable)
AZURE_API_VERSION=2024-02-01

DASHBOARD_PORT=3000
COMPOSE_PROJECT_NAME=panchayat-azure
