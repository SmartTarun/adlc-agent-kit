# ── Hybrid LLM Mode ───────────────────────────────────────────────────────────
# Ollama drafts code → quality scored → Claude improves if score < threshold.
# Both Ollama (free, local) + Claude API (paid, cloud) are used together.
#
# Usage:
#   copy .env.hybrid .env
#   docker compose -f docker-compose.hybrid.yml up --build

# Required — Claude API key (used only when Ollama score is below threshold)
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Dashboard port
DASHBOARD_PORT=3000

# Ollama settings
OLLAMA_PORT=11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_NUM_PARALLEL=2

# Claude layer settings
CLAUDE_MODEL=claude-sonnet-4-6

# Hybrid cascade settings
# Mode: ollama-first | claude-review
#   ollama-first  = Claude only kicks in when Ollama score < threshold
#   claude-review = Ollama drafts, Claude always reviews and improves
HYBRID_MODE=ollama-first

# Quality threshold (0-100). Ollama output below this goes to Claude.
# Higher = Claude is used more often. Lower = Ollama handles more.
# 75 = good balance. 90 = Claude reviews almost everything. 50 = rarely escalates.
HYBRID_QUALITY_THRESHOLD=75

# Docker project name
COMPOSE_PROJECT_NAME=panchayat-hybrid
