# ── Ollama Local LLM Mode ─────────────────────────────────────────────────────
# Copy this to .env before running docker-compose.ollama.yml
# No API key needed — fully offline.
#
# Usage:
#   cp .env.ollama .env
#   docker compose -f docker-compose.ollama.yml up --build

# No ANTHROPIC_API_KEY required

# Dashboard port (default: 3000)
DASHBOARD_PORT=3000

# Ollama port (default: 11434)
OLLAMA_PORT=11434

# Model to use for agent code generation
# Recommended options (sorted by quality vs speed):
#   qwen2.5-coder:7b    ~4GB  — best quality for code (default)
#   deepseek-coder:6.7b ~4GB  — strong alternative
#   codellama:13b       ~7GB  — Meta's code model, needs more RAM
#   qwen2.5-coder:3b    ~2GB  — fastest, less capable
OLLAMA_MODEL=qwen2.5-coder:7b

# Parallel requests Ollama handles (increase if you have more RAM)
OLLAMA_NUM_PARALLEL=2

# Docker project name
COMPOSE_PROJECT_NAME=panchayat-ollama
