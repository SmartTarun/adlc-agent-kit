# ─────────────────────────────────────────────────────────────────────────────
# ADLC Agent Kit v3 — Environment Variables
# Copy this file to .env and fill in your values.
# The .env file is git-ignored and never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Docker ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=panchayat
DASHBOARD_PORT=3000

# ── Models ───────────────────────────────────────────────────────────────────
# Arjun (orchestrator) uses Opus; all others use Sonnet
ARJUN_MODEL=claude-opus-4-5
AGENT_MODEL=claude-sonnet-4-5

# ── Tool connections (optional — used by connect-tools.js) ───────────────────
GITHUB_TOKEN=ghp_your_token_here
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=adlc
POSTGRES_USER=adlc_user
POSTGRES_PASSWORD=your_password_here

# ── AWS (optional — used by Vikram for Terraform) ────────────────────────────
AWS_PROFILE=default
AWS_REGION=us-east-1
# Or use explicit keys (not recommended — use profile instead):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
